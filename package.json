{
  "name": "denr-permit-sample",
  "version": "1.0.0",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "serve-web": "npx http-server -c-1 .",
    "predeploy": "node deploy-fix.js",
    "deploy": "wrangler deploy --config wrangler.jsonc",
    "preview": "wrangler dev --config wrangler.jsonc"
  },
  "wrangler": {
    "name": "denrpermit",
    "compatibility_date": "2026-05-02",
    "observability": {
      "enabled": true
    },
    "assets": {
      "directory": "public"
    },
    "compatibility_flags": [
      "nodejs_compat"
    ]
  },
  "dependencies": {
    "body-parser": "^1.20.2",
    "cloudinary": "^1.41.3",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "firebase-admin": "^13.8.0",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0"
  }
}
